#!/usr/bin/env bash
set -euo pipefail

# Example only. Do not commit real credentials.
#
# Prerequisites:
# - Apple Developer Program membership
# - Developer ID Application certificate for signing
# - App-specific password for the Apple ID
# - A signed ZIP or DMG produced by scripts/package-zip.sh or scripts/package-dmg.sh

APPLE_ID="${APPLE_ID:-you@example.com}"
TEAM_ID="${TEAM_ID:-TEAMID1234}"
APP_SPECIFIC_PASSWORD="${APP_SPECIFIC_PASSWORD:-xxxx-xxxx-xxxx-xxxx}"
BUNDLE_ID="${BUNDLE_ID:-com.chihentai.screenshotinbox}"
ARTIFACT_PATH="${1:-dist/ScreenshotInbox-0.1.0-alpha.zip}"

xcrun notarytool submit "$ARTIFACT_PATH" \
  --apple-id "$APPLE_ID" \
  --team-id "$TEAM_ID" \
  --password "$APP_SPECIFIC_PASSWORD" \
  --wait

# Stapling applies to .app and .dmg files. ZIP files cannot be stapled directly.
if [[ "$ARTIFACT_PATH" == *.dmg ]]; then
  xcrun stapler staple "$ARTIFACT_PATH"
  xcrun stapler validate "$ARTIFACT_PATH"
fi

spctl -a -vv --type open "$ARTIFACT_PATH"

echo "Submitted $ARTIFACT_PATH for bundle id $BUNDLE_ID"
